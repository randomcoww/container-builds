{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:githubActionsVersions"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "github-releases",
        "github-tags"
      ],
      "versioning": "docker"
    },
    {
      "matchPackageNames": [
        "isc-projects/kea",
        "awslabs/mountpoint-s3"
      ],
      "versioning": "regex:^(?<compatibility>.*)-v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)?$"
    },
    {
      "matchPackageNames": [
        "LizardByte/Sunshine"
      ],
      "ignoreUnstable": false
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "ignoreTests": true,
      "groupName": "renovate"
    },
    {
      "matchPackageNames": [
        "LizardByte/Sunshine"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "ignoreTests": true,
      "groupName": "renovate"
    },
    {
      "matchManagers": [
        "github-actions",
        "dockerfile"
      ],
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": false
    }
  ]
}
